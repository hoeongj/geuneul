# 그늘 환경변수 예시. 실제 값은 `.env`(gitignore됨)에 넣는다. 이 파일엔 placeholder만.
# 규칙 D: 실제 키/비번은 절대 커밋하지 않는다.

# --- DB / Redis (로컬 docker compose 기본값과 일치) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geuneul
DB_USERNAME=geuneul
DB_PASSWORD=geuneul
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 외부 API 키 (P1~P3에서 사용) ---
KAKAO_REST_API_KEY=          # 카카오 로컬(지오코딩) + 지도
DATA_GO_KR_API_KEY=          # 공공데이터포털(무더위쉼터/공중화장실/음수대)
KMA_API_KEY=                 # 기상청 초단기예보
CLAUDE_API_KEY=              # AI 요약/제보 분류 (곁다리)

# --- 소셜 로그인 (P2) ---
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
