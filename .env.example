# 그늘 환경변수 예시. 실제 값은 `.env`(gitignore됨)에 넣는다. 이 파일엔 placeholder만.
# 규칙 D: 실제 키/비번은 절대 커밋하지 않는다.

# --- DB / Redis (로컬 docker compose 기본값과 일치) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geuneul
DB_USERNAME=geuneul
DB_PASSWORD=geuneul
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 외부 API 키 (P1~P3에서 사용) ---
KAKAO_REST_API_KEY=          # 카카오 로컬(지오코딩) + 지도
DATA_GO_KR_API_KEY=          # 공공데이터포털(무더위쉼터/공중화장실/음수대)
KMA_API_KEY=                 # 기상청 초단기예보
CLAUDE_API_KEY=              # AI 요약/제보 분류 (곁다리)

# --- 소셜 로그인 (P2) ---
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- 배포(AWS) 참고: 실제 값은 SSM/ECS 환경변수로 주입. 레포엔 안 들어감. 절차는 DEPLOY.md. ---
# ECS task def가 DB_HOST(RDS endpoint)/DB_* 를 주입, DB_PASSWORD는 SSM SecureString.
# 배포 인증: GitHub 레포 시크릿 AWS_ROLE_ARN(Terraform output) — 액세스키 저장 안 함(OIDC).
PORT=8080
REDIS_PASSWORD=
REDIS_SSL=false
