# 그늘 환경변수 예시. 실제 값은 `.env`(gitignore됨)에 넣는다. 이 파일엔 placeholder만.
# 실제 키/비번은 절대 커밋하지 않는다.
# 이름은 backend/src/main/resources/application.yml 이 읽는 환경변수와 1:1이다.

# --- DB / Redis (로컬 docker compose 기본값과 일치) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geuneul
DB_USERNAME=geuneul
DB_PASSWORD=geuneul
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
PORT=8080

# --- 인증/보안 ---
JWT_SECRET=                  # JWT 서명 키 (openssl rand -hex 64)
KAKAO_CLIENT_SECRET=         # 카카오 로그인 Client Secret
GOOGLE_CLIENT_ID=            # 구글 로그인
GOOGLE_CLIENT_SECRET=
GEUNEUL_PROXY_SECRET=        # BFF↔백엔드 공유 시크릿(레이트리밋 신뢰경계, TS-008)

# --- 외부 API ---
KAKAO_REST_API_KEY=          # 카카오 REST — 지오코딩·키워드검색·경로·로그인
KMA_SERVICE_KEY=             # 기상청 초단기실황 (data.go.kr serviceKey)
DATA_GO_KR_SERVICE_KEY=      # 공공데이터포털 (도서관·상권 오픈API)
SAFETYDATA_SERVICE_KEY=      # 행정안전부 safetydata (무더위쉼터)
AI_SUMMARY_API_KEY=          # AI 한줄요약 — OpenAI 호환 프로바이더 키
AI_SUMMARY_BASE_URL=         # (선택) 프로바이더 base URL
AI_SUMMARY_MODEL=            # (선택) 모델명

# --- 사진 업로드 (S3 presign) ---
S3_BUCKET_NAME=
AWS_REGION=ap-northeast-2

# --- Web Push (선택, 기본 off) ---
PUSH_ENABLED=false
PUSH_VAPID_PUBLIC_KEY_PEM=
PUSH_VAPID_PRIVATE_KEY_PEM=
PUSH_VAPID_SUBJECT=

# --- 배포(AWS) 참고: 실제 값은 SSM SecureString → ECS task definition secrets 로 주입. 레포엔 안 들어감. ---
# 배포 인증: GitHub 레포 시크릿 AWS_ROLE_ARN(Terraform output) — 액세스키 저장 안 함(OIDC). 절차는 DEPLOY.md.
